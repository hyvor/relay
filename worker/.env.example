# URL where the Symfony application is running.
# Default: http://localhost:80
# Default works for production.
# In local, you need the docker compose container name of the Symfony app (which is set in compose.yaml).
GO_SYMFONY_URL=

# API key used for unauthenticated SMTP submissions.
# Required when ALLOW_UNAUTHENTICATED_SENDING=true is set on the backend.
# Create an API key in the console and set it here.
UNAUTHENTICATED_SEND_API_KEY=