{
    "type": "project",
    "license": "agpl-3.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-apcu": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-openssl": "*",
        "ext-pdo_pgsql": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.4",
        "doctrine/doctrine-migrations-bundle": "^4.0.0",
        "doctrine/orm": "^3.6.7",
        "egulias/email-validator": "^4.0.4",
        "hyvor/internal": "^4.0.14",
        "mlocati/spf-lib": "^3.3",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpmailer/phpmailer": "^6.12",
        "phpstan/phpdoc-parser": "^2.3.2",
        "promphp/prometheus_client_php": "^2.15.1",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/flex": "^2.11.0",
        "symfony/framework-bundle": "8.0.*",
        "symfony/lock": "8.0.*",
        "symfony/messenger": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/rate-limiter": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/scheduler": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/uid": "8.0.*",
        "symfony/yaml": "8.0.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*",
            "docker": false
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "phpstan/phpstan": "^2.2.2",
        "phpunit/phpunit": "^12.5.30",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/maker-bundle": "^1.67.0",
        "zenstruck/foundry": "^2.10.1",
        "zenstruck/messenger-test": "^1.14.0"
    }
}
